import java.util.Scanner;
class FindMax {
    public static void main(String[] args) {
        Scanner myObj = new Scanner(System.in);
        System.out.println("Enter three numbers");
        int x = myObj.nextInt();
        int y = myObj.nextInt();
        int z = myObj.nextInt();
        int max = x;
        if (x>max) max = x;
        if (y>max) max = y;
        if (z>max) max = z;
        System.out.println("The largest number is " + max);
    }
}
